# Variáveis de Ambiente para o Agente Financeiro

# ===== CONFIGURAÇÃO DA IA =====
# Escolha uma das opções:
# 1. OpenAI
OPENAI_API_KEY=sua_chave_api_openai_aqui

# 2. Anthropic Claude
ANTHROPIC_API_KEY=sua_chave_api_claude_aqui

# 3. Google Gemini
GOOGLE_API_KEY=sua_chave_api_gemini_aqui

# 4. Ollama (local - não requer API)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# ===== CONFIGURAÇÕES GERAIS =====
# Selecione qual LLM usar: openai, claude, gemini, ollama
LLM_PROVIDER=openai

# Modelo a ser utilizado
LLM_MODEL=gpt-4-turbo-preview

# Temperatura (criatividade): 0.0-1.0
LLM_TEMPERATURE=0.7

# Token máximo por resposta
LLM_MAX_TOKENS=2000

# ===== BANCO DE DADOS =====
# Caminho do banco SQLite (local)
DATABASE_PATH=./data/agente_financeiro.db

# Usar ChromaDB para embeddings (vetorização)
CHROMA_DB_PATH=./data/chroma_db

# ===== SEGURANÇA E CONFORMIDADE =====
# Ativar modo de segurança (validação de respostas)
SECURITY_MODE=true

# Chave para criptografia de dados sensíveis
ENCRYPTION_KEY=sua_chave_secreta_aqui

# LGPD: Habilitar conformidade com LGPD
LGPD_COMPLIANCE=true

# ===== AMBIENTE =====
# Desenvolvimento, Produção ou Teste
ENVIRONMENT=development

# Nível de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ===== STREAMILIT (UI) =====
# Tema da interface
STREAMLIT_THEME=light

# Porto padrão
STREAMLIT_SERVER_PORT=8501

# ===== CACHE E PERFORMANCE =====
# Ativar cache de respostas
ENABLE_CACHE=true

# TTL do cache em segundos (3600 = 1 hora)
CACHE_TTL=3600

# ===== MONITORAMENTO =====
# URL para enviar métricas (opcional)
METRICS_ENDPOINT=

# Token de autenticação para métricas
METRICS_TOKEN=
